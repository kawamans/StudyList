package sec2ex;

public class Item100 implements Salable, ItemComp {
	protected String name;
	
	public Item100(String name) {
		this.name = name;
	}
	
	@Override
	public String getName() {
		return this.name;
	}
	
	@Override
	public int getPrice() {
		return 100;
	}
	
	@Override
	public int compareTo(Salable other) {
		int maxNum = 0;
		int oneHunNum = getPrice();
		if (oneHunNum > maxNum) {
			maxNum = oneHunNum;
		} else if(oneHunNum == maxNum) {
			maxNum = 0;		
		}
		return maxNum;
		
	}
	
}

package sec2ex;

public class Item implements Salable, ItemComp {
	String name;
	int price;
	
	public Item(String name, int price) {
		this.name = name;
		this.price = price;
	}
	
	@Override
	public String getName() {
		return this.name;
	}
	
	@Override
	public int getPrice() {
		return this.price;
	}
	
	@Override
	public int compareTo(Salable other) {
		if (this.price > other) {
		} else if(this.price = other) {
			this.price = 0;		
		}
		return this.price;
		
	}
}
